# ── Copia este archivo a .env y edita los valores ──────────────────────────────
# cp .env.example .env

# Base de datos MySQL
MYSQL_ROOT_PASSWORD=cambia-esto-por-una-contraseña-segura
DB_NAME=aegis_db
DB_USER=aegis
DB_PASSWORD=cambia-esto-por-una-contraseña-segura

# Backend FastAPI
SECRET_KEY=cambia-esto-openssl-rand-hex-32
DEEPSEEK_API_KEY=          # Opcional: para resúmenes IA en el scanner

# Frontend Next.js
NEXTAUTH_URL=https://TU_DOMINIO.COM    # ← cambia por tu dominio o IP pública
NEXTAUTH_SECRET=cambia-esto-openssl-rand-hex-32
NEXT_PUBLIC_API_URL=https://TU_DOMINIO.COM:8000   # URL pública del backend
